# Copy to .env and fill in. All PUBLIC_* vars are exposed to the client at build time.

# AI Tool Finder (/api/recommend). Server-only — never exposed to the client.
# Get a key at https://platform.claude.com/ — without it the finder falls back
# to showing top-rated tools.
ANTHROPIC_API_KEY=

# Email capture form action URL (MailerLite / ConvertKit / Buttondown form endpoint).
# Until set, the signup forms render but post nowhere.
PUBLIC_EMAIL_FORM_ACTION=

# Analytics — set ONE of these (Plausible wins if both are set).
# Your Plausible site domain, e.g. toolstackreviews.com
PUBLIC_PLAUSIBLE_DOMAIN=
# Your GA4 measurement ID, e.g. G-XXXXXXXXXX
PUBLIC_GA4_ID=
