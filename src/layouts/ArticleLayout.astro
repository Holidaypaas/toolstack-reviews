---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import AuthorByline from '../components/AuthorByline.astro';
import LastUpdated from '../components/LastUpdated.astro';
import TableOfContents from '../components/TableOfContents.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { personSchema, type Crumb } from '../lib/seo';

/**
 * Shared layout for reviews, comparisons, guides, and roundups.
 * Renders: title block, byline, FTC disclosure (when hasAffiliateLinks),
 * sticky TOC on desktop, the article body (slot), and an end-of-post signup.
 */
interface Props {
  title: string;
  description: string;
  publishDate: Date;
  lastUpdated: Date;
  author: CollectionEntry<'authors'>;
  headings: MarkdownHeading[];
  breadcrumbs: Crumb[];
  /** Shows the FTC disclosure — true for reviews/comparisons/roundups. */
  hasAffiliateLinks?: boolean;
  ogImage?: string;
  jsonLd?: object[];
}

const {
  title,
  description,
  publishDate,
  lastUpdated,
  author,
  headings,
  breadcrumbs,
  hasAffiliateLinks = false,
  ogImage,
  jsonLd = [],
} = Astro.props;

const allJsonLd = [personSchema(author.data), ...jsonLd];
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
  breadcrumbs={breadcrumbs}
  jsonLd={allJsonLd}
>
  <div class="mx-auto max-w-5xl px-4 py-8 lg:py-12">
    <nav aria-label="Breadcrumb" class="mb-6 font-mono text-xs text-ink-faint">
      <ol class="flex flex-wrap items-center gap-1.5">
        {
          breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              {i > 0 && <span aria-hidden="true">/</span>}
              {i === breadcrumbs.length - 1 ? (
                <span aria-current="page" class="text-ink-muted">{crumb.name}</span>
              ) : (
                <a href={crumb.url} class="hover:text-accent-700">{crumb.name}</a>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    <header class="max-w-[720px]">
      <LastUpdated date={lastUpdated} />
      <h1 class="font-display text-display mt-4 font-bold text-ink">
        {title}
      </h1>
      <p class="mt-3 text-lg leading-relaxed text-ink-muted">{description}</p>
      <AuthorByline author={author} publishDate={publishDate} class="mt-5" />
    </header>

    <div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,720px)_280px]">
      <div>
        {hasAffiliateLinks && <AffiliateDisclosure />}
        <div class="lg:hidden">
          <TableOfContents headings={headings} />
        </div>
        <article class="prose prose-slate mt-6 max-w-none prose-headings:font-bold prose-headings:tracking-tight lg:mt-0">
          <slot />
        </article>
        <EmailSignup variant="endofpost" />
      </div>
      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
