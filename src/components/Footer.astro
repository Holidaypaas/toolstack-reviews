---
import { SITE } from '../config/site';

const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Content',
    links: [
      { label: 'Tool Reviews', href: '/reviews/' },
      { label: 'Comparisons', href: '/vs/' },
      { label: 'Best Tools', href: '/best/' },
      { label: 'Blog', href: '/blog/' },
      { label: 'AI Tool Finder', href: '/tool-finder/' },
    ],
  },
  {
    heading: 'Trust',
    links: [
      { label: 'How We Test', href: '/how-we-test/' },
      { label: 'About', href: '/about/' },
      { label: 'Affiliate Disclosure', href: '/affiliate-disclosure/' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy-policy/' },
      { label: 'Terms', href: '/terms/' },
      { label: 'RSS Feed', href: '/rss.xml' },
    ],
  },
];
---

<footer class="mt-16 border-t border-line bg-paper-raised">
  <div class="mx-auto max-w-5xl px-4 py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div class="max-w-xs">
        <img
          src="/brand/logo-horizontal.svg"
          alt={SITE.name}
          width="145"
          height="40"
          class="h-10 w-auto"
        />
        <p class="mt-3 text-sm leading-relaxed text-ink-muted">{SITE.description}</p>
        <a
          href="/how-we-test/"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-accent-700 hover:underline"
        >
          Read our testing methodology
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
      </div>
      {
        columns.map((column) => (
          <nav aria-label={`${column.heading} links`}>
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.15em] text-ink-faint">
              {column.heading}
            </p>
            <ul class="mt-3 space-y-2 text-sm">
              {column.links.map((link) => (
                <li>
                  <a href={link.href} class="text-ink-muted hover:text-accent-700">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
    <p class="mt-10 border-t border-line pt-6 text-xs leading-relaxed text-ink-faint">
      Some links on this site are affiliate links. If you buy through them, we may
      earn a commission at no extra cost to you. This never affects our scores —
      ratings are locked before affiliate programs are considered.
    </p>
    <p class="mt-2 font-mono text-[11px] text-ink-faint">
      &copy; {year} {SITE.name}. All rights reserved.
    </p>
    <!-- TODO: add a cookie-consent banner before enabling ad/marketing cookies -->
  </div>
</footer>
