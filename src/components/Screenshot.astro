---
import { Image } from 'astro:assets';

/**
 * Captioned screenshot figure — 16:10, subtle border, mono caption.
 * Used by the review template for the `screenshots` frontmatter array;
 * also importable directly in MDX.
 */
interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="not-prose my-8">
  <div class="overflow-hidden rounded-lg border border-line bg-paper-raised shadow-sm">
    <div class="flex items-center gap-1.5 border-b border-line bg-paper px-3 py-2" aria-hidden="true">
      <span class="h-2 w-2 rounded-full bg-line-strong"></span>
      <span class="h-2 w-2 rounded-full bg-line-strong"></span>
      <span class="h-2 w-2 rounded-full bg-line-strong"></span>
    </div>
    <Image
      src={src}
      alt={alt}
      width={1280}
      height={800}
      class="aspect-[16/10] w-full object-cover object-top"
      loading="lazy"
    />
  </div>
  <figcaption class="mt-2 font-mono text-xs text-ink-faint">
    {caption}
  </figcaption>
</figure>
