---
import { SITE } from '../config/site';

const nav = [
  { label: 'Reviews', href: '/reviews/' },
  { label: 'Comparisons', href: '/vs/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'How We Test', href: '/how-we-test/' },
  { label: 'About', href: '/about/' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="shrink-0" aria-label={`${SITE.name} home`}>
      <img
        src="/brand/logo-horizontal.svg"
        alt={SITE.name}
        width="175"
        height="48"
        class="h-10 w-auto sm:h-12"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:block" aria-label="Main navigation">
      <ul class="flex items-center gap-x-5 text-sm font-medium">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
                class:list={[
                  'py-1 transition-colors hover:text-accent-700',
                  currentPath.startsWith(item.href)
                    ? 'font-semibold text-accent-700'
                    : 'text-ink-muted',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href="/tool-finder/"
            class:list={[
              'btn-press rounded-lg border-2 px-3 py-1.5 text-sm font-bold transition-colors',
              currentPath.startsWith('/tool-finder')
                ? 'border-accent-700 bg-accent-700 text-white'
                : 'border-accent-600 text-accent-700 hover:bg-accent-600 hover:text-white',
            ]}
          >
            Tool Finder
          </a>
        </li>
      </ul>
    </nav>

    <!-- Mobile: compact CTA + hamburger button -->
    <div class="flex items-center gap-2 md:hidden">
      <a
        href="/tool-finder/"
        class="rounded-lg bg-accent-600 px-3 py-2 text-xs font-bold text-white"
      >
        Tool Finder
      </a>
      <button
        id="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu"
        class="flex h-9 w-9 flex-col items-center justify-center gap-[5px] rounded-lg border border-line text-ink transition-colors hover:border-accent-600 hover:text-accent-700"
      >
        <span id="bar1" class="block h-px w-5 bg-current transition-all duration-200 origin-center"></span>
        <span id="bar2" class="block h-px w-5 bg-current transition-all duration-200"></span>
        <span id="bar3" class="block h-px w-5 bg-current transition-all duration-200 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <nav
    id="mobile-nav"
    class="hidden border-t border-line bg-paper-raised pb-4 md:hidden"
    aria-label="Mobile navigation"
  >
    <ul class="space-y-0.5 px-3 pt-3">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
              class:list={[
                'flex items-center rounded-lg px-3 py-3 text-sm font-medium transition-colors',
                currentPath.startsWith(item.href)
                  ? 'bg-accent-50 font-semibold text-accent-700'
                  : 'text-ink hover:bg-paper hover:text-accent-700',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-nav');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  function openNav() {
    panel?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close menu');
    bar1?.classList.add('translate-y-[6px]', 'rotate-45');
    bar2?.classList.add('opacity-0');
    bar3?.classList.add('-translate-y-[6px]', '-rotate-45');
  }

  function closeNav() {
    panel?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open menu');
    bar1?.classList.remove('translate-y-[6px]', 'rotate-45');
    bar2?.classList.remove('opacity-0');
    bar3?.classList.remove('-translate-y-[6px]', '-rotate-45');
  }

  toggle?.addEventListener('click', () => {
    toggle.getAttribute('aria-expanded') === 'true' ? closeNav() : openNav();
  });

  // Close when a mobile link is tapped
  panel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeNav));
</script>
