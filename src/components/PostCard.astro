---
import Glyph from './Glyph.astro';
import ScoreBadge from './ScoreBadge.astro';
import type { CATEGORIES } from '../content.config';

interface Props {
  href: string;
  title: string;
  /** One-line verdict / description. */
  description: string;
  category?: (typeof CATEGORIES)[number];
  score?: number;
  lastUpdated?: Date;
  badge?: string;
}

const {
  href,
  title,
  description,
  category = 'productivity',
  score,
  lastUpdated,
  badge,
} = Astro.props;
---

<article
  class="card-lift group relative flex flex-col overflow-hidden rounded-lg border border-line bg-paper-raised shadow-sm"
>
  <Glyph name={category} variant="thumb" class="h-32 w-full" />
  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-base font-bold leading-snug tracking-tight text-ink">
        <a
          href={href}
          class="after:absolute after:inset-0 group-hover:text-accent-700 focus-visible:outline-none"
        >
          {title}
        </a>
      </h3>
      {score !== undefined && <ScoreBadge score={score} size="sm" class="shrink-0" />}
    </div>
    {
      badge && (
        <span class="mt-2 w-fit rounded-full bg-accent-50 px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-wider text-accent-700">
          {badge}
        </span>
      )
    }
    <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-ink-muted">
      {description}
    </p>
    {
      lastUpdated && (
        <p class="mt-auto pt-3 font-mono text-[11px] text-ink-faint">
          Updated{' '}
          <time datetime={lastUpdated.toISOString().slice(0, 10)}>
            {lastUpdated.toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            })}
          </time>
        </p>
      )
    }
  </div>
</article>
