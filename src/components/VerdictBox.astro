---
import ScoreCard from './ScoreCard.astro';
import type { Scores } from '../lib/score';

/**
 * Prominent verdict card shown at the TOP of every review.
 * Carries the full test-score card. The CTA must point at an
 * internal /go/ link (see src/config/affiliates.ts).
 */
interface Props {
  toolName: string;
  scores: Scores;
  verdict: string;
  pricingFrom: string;
  /** Internal redirect path, e.g. "/go/systeme-io/" */
  ctaHref: string;
  ctaLabel?: string;
}

const {
  toolName,
  scores,
  verdict,
  pricingFrom,
  ctaHref,
  ctaLabel = `Try ${toolName} free`,
} = Astro.props;
---

<aside class="not-prose my-8" aria-label={`Our verdict on ${toolName}`}>
  <ScoreCard toolName={toolName} scores={scores} />
  <div class="rounded-b-lg border-2 border-t-0 border-line bg-paper-raised px-5 pb-5 pt-4">
    <p class="font-display text-xs font-bold uppercase tracking-[0.15em] text-ink-faint">
      The verdict
    </p>
    <p class="mt-2 text-base leading-relaxed text-ink">{verdict}</p>
    <div class="mt-5 flex flex-wrap items-center gap-4">
      <a
        href={ctaHref}
        rel="sponsored noopener"
        class="btn-press inline-flex items-center gap-2 rounded-lg bg-accent-600 px-6 py-3 text-base font-bold text-white shadow-md transition-colors hover:bg-accent-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 focus-visible:ring-offset-2"
      >
        {ctaLabel}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
      <span class="text-sm text-ink-muted">
        Pricing from <strong class="font-mono font-bold text-ink">{pricingFrom}</strong>
      </span>
    </div>
  </div>
</aside>
