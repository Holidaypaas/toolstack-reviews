---
/**
 * GEO fact box — 4-6 verifiable stats (pricing, limits, scores) with an
 * explicit as-of date, rendered near the top of the article. Each fact is
 * also emitted as schema.org PropertyValue JSON-LD so AI search engines
 * can attribute the numbers to a dated source.
 */
export interface Fact {
  label: string;
  value: string;
}

interface Props {
  facts: Fact[];
  /** When these numbers were last verified — usually the post's lastUpdated. */
  asOf: Date;
  /** What the facts describe, e.g. the tool name. Used in JSON-LD. */
  subject: string;
  /** Set false when the parent template already merges facts into its Product schema. */
  emitJsonLd?: boolean;
}

const { facts, asOf, subject, emitJsonLd = true } = Astro.props;
const asOfFormatted = asOf.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Key facts: ${subject}`,
  dateModified: asOf.toISOString().slice(0, 10),
  itemListElement: facts.map((fact, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: { '@type': 'PropertyValue', name: fact.label, value: fact.value },
  })),
};
---

<section
  class="not-prose my-6 rounded-lg border border-line bg-paper-raised p-5"
  aria-label={`Key facts about ${subject}`}
>
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <h2 class="font-display text-sm font-bold uppercase tracking-wide text-ink">
      Key facts
    </h2>
    <span class="font-mono text-[11px] text-ink-faint">
      Verified <time datetime={asOf.toISOString().slice(0, 10)}>{asOfFormatted}</time>
    </span>
  </div>
  <dl class="mt-3 grid gap-x-6 gap-y-2 sm:grid-cols-2">
    {
      facts.map((fact) => (
        <div class="flex items-baseline justify-between gap-3 border-b border-line/70 pb-1.5">
          <dt class="text-[13px] text-ink-muted">{fact.label}</dt>
          <dd class="text-right font-mono text-[13px] font-semibold text-ink">{fact.value}</dd>
        </div>
      ))
    }
  </dl>
</section>

{emitJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
