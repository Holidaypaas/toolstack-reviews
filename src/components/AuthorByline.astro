---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  author: CollectionEntry<'authors'>;
  publishDate?: Date;
  class?: string;
}

const { author, publishDate, class: className } = Astro.props;
const { name, role, avatar } = author.data;
---

<div class:list={['flex items-center gap-3', className]}>
  <Image
    src={avatar}
    alt={`Photo of ${name}`}
    width={40}
    height={40}
    class="h-10 w-10 rounded-full border border-slate-200 object-cover"
    loading="eager"
  />
  <div class="text-sm leading-tight">
    <a href="/about/" class="font-semibold text-slate-900 hover:text-accent-700">
      {name}
    </a>
    <p class="text-slate-500">
      {role}{
        publishDate && (
          <>
            {' · '}
            <time datetime={publishDate.toISOString().slice(0, 10)}>
              {publishDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </>
        )
      }
    </p>
  </div>
</div>
