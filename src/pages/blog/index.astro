---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const roundups = (await getCollection('roundups')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title="Blog — Guides & Roundups"
  description="Practical guides and best-of roundups to help freelancers pick the right software."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog/' },
  ]}
>
  <div class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="font-display text-display-sm font-bold text-ink">Blog</h1>
    <p class="mt-3 max-w-xl text-lg text-ink-muted">
      Guides and best-of lists for running a leaner solo business.
    </p>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        roundups.map((r) => (
          <PostCard
            href={`/best/${r.id}/`}
            title={r.data.title}
            description={r.data.description}
            category={r.data.category}
            lastUpdated={r.data.lastUpdated}
            badge="Best of"
          />
        ))
      }
      {
        guides.map((g) => (
          <PostCard
            href={`/blog/${g.id}/`}
            title={g.data.title}
            description={g.data.description}
            category={g.data.category}
            lastUpdated={g.data.lastUpdated}
            badge="Guide"
          />
        ))
      }
    </div>
  </div>
</BaseLayout>
