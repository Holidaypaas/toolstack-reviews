---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import EmailSignup from '../components/EmailSignup.astro';
import ScoreCard from '../components/ScoreCard.astro';
import { SITE } from '../config/site';
import { overallScore, formatScore } from '../lib/score';

const reviews = (await getCollection('reviews')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const comparisons = (await getCollection('comparisons')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const roundups = (await getCollection('roundups')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const heroReview = reviews[0];

const startHere = [
  {
    title: 'How we test tools',
    description: 'Real accounts, real money, 2+ weeks of daily use before we write a word.',
    href: '/how-we-test/',
    icon: '🧪',
  },
  ...roundups.slice(0, 1).map((r) => ({
    title: r.data.title,
    description: r.data.description,
    href: `/best/${r.id}/`,
    icon: '⭐',
  })),
  ...comparisons.slice(0, 1).map((c) => ({
    title: c.data.title,
    description: c.data.description,
    href: `/vs/${c.id}/`,
    icon: '⚖️',
  })),
];
---

<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description}>

  <!-- ── Hero: dark background, high contrast ── -->
  <section class="bg-ink">
    <div class="mx-auto max-w-5xl px-4 py-14 sm:py-20">
      <div class="hero-rise grid items-center gap-10 lg:grid-cols-[1.1fr_1fr]">

        <!-- Copy -->
        <div>
          <p class="font-mono text-xs font-bold uppercase tracking-[0.22em] text-accent-400">
            Tested · Scored · Evidenced
          </p>
          <h1 class="font-display text-display mt-4 font-bold leading-[1.1] text-paper">
            Software reviews from someone who actually pays for the tools.
          </h1>
          <p class="mt-5 max-w-xl text-base leading-relaxed text-paper/60 sm:text-lg">
            Every score on {SITE.name} comes from weeks of real use with a paid account,
            graded on the same rubric every time. No sponsored rankings, no pay-to-win lists.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/reviews/"
              class="btn-press inline-flex items-center gap-2 rounded-xl bg-accent-500 px-6 py-3 text-base font-bold text-ink shadow-lg transition-colors hover:bg-accent-400"
            >
              Browse reviews
            </a>
            <a
              href="/how-we-test/"
              class="btn-press inline-flex items-center gap-2 rounded-xl border border-paper/20 bg-paper/10 px-6 py-3 text-base font-semibold text-paper transition-colors hover:bg-paper/20"
            >
              How we test →
            </a>
          </div>

          <!-- Mobile: compact score teaser (hidden on lg where ScoreCard shows) -->
          {heroReview && (
            <a
              href={`/reviews/${heroReview.id}/`}
              class="mt-8 flex items-center gap-4 rounded-xl border border-paper/10 bg-paper/5 px-4 py-3 transition-colors hover:bg-paper/10 lg:hidden"
            >
              <div class="shrink-0 text-center">
                <p class="font-mono text-3xl font-bold leading-none text-score-400">
                  {formatScore(overallScore(heroReview.data.scores))}
                </p>
                <p class="mt-0.5 font-mono text-[9px] uppercase tracking-widest text-paper/40">/10</p>
              </div>
              <div class="min-w-0">
                <p class="font-mono text-[11px] uppercase tracking-wide text-accent-400">Latest test</p>
                <p class="mt-0.5 truncate font-display text-sm font-bold text-paper">
                  {heroReview.data.toolName}
                </p>
                <p class="mt-0.5 truncate text-xs text-paper/50">{heroReview.data.verdict}</p>
              </div>
              <span class="ml-auto shrink-0 text-paper/30" aria-hidden="true">→</span>
            </a>
          )}
        </div>

        <!-- Desktop: full ScoreCard -->
        {heroReview && (
          <div class="relative hidden lg:block">
            <ScoreCard
              toolName={heroReview.data.toolName}
              scores={heroReview.data.scores}
              class="rotate-1 shadow-2xl"
            />
            <a
              href={`/reviews/${heroReview.id}/`}
              class="mt-3 block text-right font-mono text-[11px] text-paper/30 transition-colors hover:text-accent-400"
            >
              ↑ Latest test: {heroReview.data.toolName} — read the full review
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ── Trust bar ── -->
  <section class="border-b border-line bg-paper-raised">
    <div class="mx-auto max-w-5xl px-4 py-5">
      <dl class="grid grid-cols-3 divide-x divide-line text-center">
        <div class="px-4 py-2">
          <dt class="font-mono text-[11px] uppercase tracking-widest text-ink-faint">Tools tested</dt>
          <dd class="mt-1 font-mono text-2xl font-bold text-ink">{reviews.length}+</dd>
        </div>
        <div class="px-4 py-2">
          <dt class="font-mono text-[11px] uppercase tracking-widest text-ink-faint">Min test time</dt>
          <dd class="mt-1 font-mono text-2xl font-bold text-ink">2 wks</dd>
        </div>
        <div class="px-4 py-2">
          <dt class="font-mono text-[11px] uppercase tracking-widest text-ink-faint">Paid accounts</dt>
          <dd class="mt-1 font-mono text-2xl font-bold text-ink">100%</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ── AI Tool Finder teaser ── -->
  <section class="border-b border-line bg-accent-600">
    <div class="mx-auto max-w-5xl px-4 py-10">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
        <div>
          <p class="font-mono text-[11px] font-bold uppercase tracking-[0.2em] text-accent-100/80">
            New · AI Tool Finder
          </p>
          <h2 class="font-display mt-2 text-xl font-bold tracking-tight text-white sm:text-2xl">
            Describe your business. Get a stack built from our test results.
          </h2>
          <p class="mt-2 max-w-lg text-sm leading-relaxed text-white/70">
            Tell us what you do and your budget — we'll match you to the highest-scoring tools
            from our hands-on reviews. Only tools we've actually tested.
          </p>
        </div>
        <a
          href="/tool-finder/"
          class="btn-press shrink-0 rounded-xl bg-white px-6 py-3 text-base font-bold text-accent-700 shadow-lg transition-colors hover:bg-accent-50"
        >
          Find my stack →
        </a>
      </div>
    </div>
  </section>

  <!-- ── Latest reviews ── -->
  <section class="mx-auto max-w-5xl px-4 py-14">
    <div class="flex items-baseline justify-between">
      <h2 class="font-display text-2xl font-bold tracking-tight text-ink">Latest reviews</h2>
      <a href="/reviews/" class="text-sm font-semibold text-accent-700 hover:underline">
        View all →
      </a>
    </div>
    <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        reviews.slice(0, 6).map((review) => (
          <PostCard
            href={`/reviews/${review.id}/`}
            title={`${review.data.toolName} review`}
            description={review.data.verdict}
            category={review.data.category}
            score={overallScore(review.data.scores)}
            lastUpdated={review.data.lastUpdated}
          />
        ))
      }
    </div>
  </section>

  <!-- ── Start here ── -->
  <section class="border-y border-line bg-paper-raised">
    <div class="mx-auto max-w-5xl px-4 py-14">
      <h2 class="font-display text-2xl font-bold tracking-tight text-ink">New here? Start with these</h2>
      <p class="mt-2 text-ink-muted">The three pages that put everything else in context.</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        {
          startHere.map((item) => (
            <a
              href={item.href}
              class="card-lift group flex flex-col gap-3 rounded-xl border border-line bg-paper p-5 shadow-sm"
            >
              <h3 class="font-display text-base font-bold tracking-tight text-ink group-hover:text-accent-700">
                {item.title}
              </h3>
              <p class="text-sm leading-relaxed text-ink-muted">{item.description}</p>
              <span class="mt-auto font-mono text-xs font-semibold text-accent-600">
                Read more →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── Email signup ── -->
  <section class="mx-auto max-w-5xl px-4 py-14">
    <EmailSignup variant="inline" />
  </section>

</BaseLayout>
