---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title="Terms of Service"
  description={`Terms of use for ${SITE.name}: content accuracy, liability, and intellectual property.`}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Terms', url: '/terms/' },
  ]}
>
  <div class="mx-auto max-w-[720px] px-4 py-12">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">
      Terms of service
    </h1>
    <div class="prose prose-slate mt-8 max-w-none">
      <!-- TODO: have a lawyer review this page before launch. This is plausible placeholder copy, not legal advice. -->
      <p><em>Last updated: June 12, 2026</em></p>

      <h2>Acceptance of terms</h2>
      <p>
        By accessing {SITE.name}, you agree to these terms. If you don't agree,
        please don't use the site.
      </p>

      <h2>Content accuracy</h2>
      <p>
        Reviews reflect our honest experience at the time of testing. Software
        changes constantly — prices, features, and policies may differ by the
        time you read a review. Always verify current pricing on the vendor's
        site before purchasing. The "Last updated" date on each post indicates
        when it was last verified.
      </p>

      <h2>No professional advice</h2>
      <p>
        Content on this site is for informational purposes only and does not
        constitute business, financial, or legal advice. Decisions you make
        based on our content are your own responsibility.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        {SITE.name} is provided "as is." We are not liable for any damages
        arising from your use of the site or from products purchased through
        links on it. Your relationship with any vendor is governed by that
        vendor's own terms.
      </p>

      <h2>Intellectual property</h2>
      <p>
        All original content is © {SITE.name}. You may quote brief excerpts
        with attribution and a link; republishing full articles requires
        written permission. Product names and logos belong to their respective
        owners.
      </p>

      <h2>Changes</h2>
      <p>
        We may update these terms at any time; continued use of the site after
        changes constitutes acceptance of the new terms.
      </p>
    </div>
  </div>
</BaseLayout>
